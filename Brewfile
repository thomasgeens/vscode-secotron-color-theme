# Brewfile — run `brew bundle` or `make brew` to install required tools

# GitHub CLI
brew "gh"

# Fuzzy finder — used by git aliases (fixup, cloneorg)
brew "fzf"

# Node.js runtime
brew "node"

# Trunk — linting orchestrator (macOS cask; Linux: curl https://get.trunk.io -fsSL | bash)
cask "trunk-io"
