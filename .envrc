# shellcheck shell=bash
# direnv — auto-loaded when entering this directory.
# Install: brew install direnv
# Then add the hook to your shell rc:
#   zsh:  eval "$(direnv hook zsh)"   → ~/.zshrc
#   bash: eval "$(direnv hook bash)"  → ~/.bashrc
# Run `direnv allow` once per machine after cloning.
#
# Secrets go in .envrc.local (gitignored — never committed).
# Copy the example and fill in your values:
#   cp .envrc.local.example .envrc.local
# Or run: make setup  (does this automatically)

source_env_if_exists .envrc.local
