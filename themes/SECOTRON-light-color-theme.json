{
  "$schema": "vscode://schemas/color-theme",
  "type": "light",
  "colors": {
    "activityBar.background": "#c4d8ee",
    "activityBar.foreground": "#0c1d45",
    "activityBar.inactiveForeground": "#437c9099",
    "activityBar.border": "#b0cce4",
    "activityBarBadge.background": "#0c1d45",
    "activityBarBadge.foreground": "#ffffff",
    "badge.background": "#437c90cc",
    "badge.foreground": "#ffffff",
    "debugToolBar.background": "#eef4fb",
    "dropdown.background": "#eef4fb",
    "editor.background": "#f0f4fb",
    "editor.foreground": "#0c1d45",
    "editor.inactiveSelectionBackground": "#d0dcea",
    "editor.lineHighlightBackground": "#dce8f566",
    "editor.selectionBackground": "#b8d4ee",
    "editor.selectionHighlightBackground": "#437c9026",
    "editorCursor.foreground": "#0c1d45",
    "editorGroup.border": "#c4d8ee",
    "editorGroup.dropBackground": "#437c9033",
    "editorGroupHeader.tabsBackground": "#dce8f5",
    "editorHoverWidget.background": "#eef4fb",
    "editorHoverWidget.border": "#0c1d4530",
    "editorIndentGuide.activeBackground": "#999999",
    "editorIndentGuide.background": "#cccccc",
    "editorLineNumber.activeForeground": "#437c90",
    "editorWhitespace.foreground": "#c4d8ee",
    "editorWidget.background": "#eef4fb",
    "errorForeground": "#a1173c",
    "focusBorder": "#437c90",
    "input.background": "#ffffff",
    "input.placeholderForeground": "#999999",
    "list.activeSelectionBackground": "#b8d4ee",
    "list.dropBackground": "#dce8f5",
    "list.focusBackground": "#b8d4ee",
    "list.highlightForeground": "#437c90",
    "list.hoverBackground": "#e4eef8",
    "list.inactiveSelectionBackground": "#ccdded",
    "menu.background": "#ffffff",
    "menu.foreground": "#0c1d45",
    "minimap.selectionHighlight": "#b8d4ee",
    "peekViewResult.background": "#eef4fb",
    "pickerGroup.foreground": "#437c90",
    "progressBar.background": "#437c90",
    "settings.numberInputBackground": "#ffffff",
    "settings.textInputBackground": "#ffffff",
    "sideBar.background": "#dce8f5",
    "sideBarSectionHeader.background": "#00000000",
    "sideBarSectionHeader.border": "#0c1d4520",
    "sideBarTitle.foreground": "#0c1d45",
    "statusBar.background": "#0c1d45",
    "statusBar.debuggingBackground": "#0c1d45",
    "statusBar.noFolderBackground": "#0c1d45",
    "statusBarItem.remoteBackground": "#0e639c",
    "statusBarItem.remoteForeground": "#ffffff",
    "tab.inactiveBackground": "#cddeed",
    "terminal.ansiBlack": "#333333",
    "terminal.ansiBlue": "#1a5c7a",
    "terminal.ansiBrightBlack": "#666666",
    "terminal.ansiBrightBlue": "#437c90",
    "terminal.ansiBrightCyan": "#267f99",
    "terminal.ansiBrightGreen": "#3a7a5a",
    "terminal.ansiBrightMagenta": "#7a3d8a",
    "terminal.ansiBrightRed": "#a0001a",
    "terminal.ansiBrightWhite": "#333333",
    "terminal.ansiBrightYellow": "#9a7520",
    "terminal.ansiCyan": "#267f99",
    "terminal.ansiGreen": "#3a7a5a",
    "terminal.ansiMagenta": "#437c90",
    "terminal.ansiRed": "#9a7520",
    "terminal.ansiWhite": "#555555",
    "terminal.ansiYellow": "#9a7520",
    "titleBar.activeBackground": "#dce8f5",
    "titleBar.activeForeground": "#0c1d45",
    "titleBar.inactiveBackground": "#e8f0fb",
    "titleBar.inactiveForeground": "#0c1d4599",
    "titleBar.border": "#b0cce4"
  },
  "tokenColors": [
    {
      "scope": ["meta.embedded", "source.groovy.embedded"],
      "settings": { "foreground": "#0c1d45" }
    },
    { "scope": "emphasis", "settings": { "fontStyle": "italic" } },
    { "scope": "strong", "settings": { "fontStyle": "bold" } },
    { "scope": "header", "settings": { "foreground": "#000080" } },
    { "scope": "comment", "settings": { "foreground": "#1f5c3d" } },
    { "scope": "constant.language", "settings": { "foreground": "#0d3d54" } },
    {
      "scope": [
        "constant.numeric",
        "entity.name.operator.custom-literal.number",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": { "foreground": "#066040" }
    },
    { "scope": "constant.regexp", "settings": { "foreground": "#646695" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#135f78" } },
    { "scope": "entity.name.tag.css", "settings": { "foreground": "#6e5010" } },
    {
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#000e50" }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.class.mixin.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.parent-selector.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css",
        "source.css.less entity.other.attribute-name.id",
        "entity.other.attribute-name.attribute.scss",
        "entity.other.attribute-name.scss"
      ],
      "settings": { "foreground": "#6e5010" }
    },
    { "scope": "invalid", "settings": { "foreground": "#800010" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    {
      "scope": "markup.bold",
      "settings": { "foreground": "#0d3d54", "fontStyle": "bold" }
    },
    {
      "scope": "markup.heading",
      "settings": { "foreground": "#0d3d54", "fontStyle": "bold" }
    },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#1f5c3d" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#7a3010" } },
    { "scope": "markup.changed", "settings": { "foreground": "#0d3d54" } },
    {
      "scope": "punctuation.definition.quote.begin.markdown",
      "settings": { "foreground": "#1f5c3d" }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": { "foreground": "#1a5c7a" }
    },
    {
      "scope": "markup.inline.raw",
      "settings": { "foreground": "#7a3010" }
    },
    {
      "scope": "punctuation.definition.tag",
      "settings": { "foreground": "#666666" }
    },
    {
      "scope": ["meta.preprocessor", "entity.name.function.preprocessor"],
      "settings": { "foreground": "#0d3d54" }
    },
    {
      "scope": "meta.preprocessor.string",
      "settings": { "foreground": "#7a3010" }
    },
    {
      "scope": "meta.preprocessor.numeric",
      "settings": { "foreground": "#066040" }
    },
    {
      "scope": "meta.structure.dictionary.key.python",
      "settings": { "foreground": "#000e50" }
    },
    {
      "scope": "meta.diff.header",
      "settings": { "foreground": "#0d3d54" }
    },
    { "scope": "storage", "settings": { "foreground": "#1a5c7a" } },
    { "scope": "storage.type", "settings": { "foreground": "#1a5c7a" } },
    {
      "scope": ["storage.modifier", "keyword.operator.noexcept"],
      "settings": { "foreground": "#1a5c7a" }
    },
    {
      "scope": ["string", "entity.name.operator.custom-literal.string", "meta.embedded.assembly"],
      "settings": { "foreground": "#7a3010" }
    },
    { "scope": "string.tag", "settings": { "foreground": "#7a3010" } },
    { "scope": "string.value", "settings": { "foreground": "#7a3010" } },
    { "scope": "string.regexp", "settings": { "foreground": "#600010" } },
    {
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#1a5c7a" }
    },
    {
      "scope": ["meta.template.expression"],
      "settings": { "foreground": "#0c1d45" }
    },
    {
      "scope": [
        "support.type.vendored.property-name",
        "support.type.property-name",
        "variable.css",
        "variable.scss",
        "variable.other.less",
        "source.coffee.embedded"
      ],
      "settings": { "foreground": "#000e50" }
    },
    { "scope": "keyword", "settings": { "foreground": "#1a5c7a" } },
    { "scope": "keyword.control", "settings": { "foreground": "#1a5c7a" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#0c1d45" } },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.alignof",
        "keyword.operator.typeid",
        "keyword.operator.alignas",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "keyword.operator.wordlike"
      ],
      "settings": { "foreground": "#1a5c7a" }
    },
    {
      "scope": "keyword.other.unit",
      "settings": { "foreground": "#066040" }
    },
    {
      "scope": [
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php"
      ],
      "settings": { "foreground": "#1a5c7a" }
    },
    {
      "scope": "support.function.git-rebase",
      "settings": { "foreground": "#000e50" }
    },
    {
      "scope": "constant.sha.git-rebase",
      "settings": { "foreground": "#066040" }
    },
    {
      "scope": [
        "storage.modifier.import.java",
        "variable.language.wildcard.java",
        "storage.modifier.package.java"
      ],
      "settings": { "foreground": "#0c1d45" }
    },
    { "scope": "variable.language", "settings": { "foreground": "#1a5c7a" } },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "support.constant.handlebars",
        "source.powershell variable.other.member",
        "entity.name.operator.custom-literal"
      ],
      "settings": { "foreground": "#6e5010" }
    },
    {
      "scope": [
        "meta.return-type",
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.namespace",
        "entity.other.attribute",
        "entity.name.scope-resolution",
        "entity.name.class"
      ],
      "settings": { "foreground": "#135f78" }
    },
    {
      "scope": [
        "keyword.control",
        "source.cpp keyword.operator.new",
        "keyword.operator.delete",
        "keyword.other.using",
        "keyword.other.operator",
        "entity.name.operator"
      ],
      "settings": { "foreground": "#5c1e70" }
    },
    {
      "scope": ["variable", "meta.definition.variable.name", "support.variable", "entity.name.variable"],
      "settings": { "foreground": "#000e50" }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": { "foreground": "#135f78" }
    },
    {
      "scope": ["meta.object-literal.key"],
      "settings": { "foreground": "#000e50" }
    },
    {
      "scope": "comment",
      "settings": { "foreground": "#1f5c3d" }
    },
    {
      "scope": "keyword.control",
      "settings": { "foreground": "#0d3d54" }
    },
    {
      "scope": "keyword.operator.class, keyword.operator, constant.other, source.php.embedded.line",
      "settings": { "foreground": "#0c1d45", "fontStyle": "" }
    },
    {
      "scope": "variable, support.other.variable, string.other.link, string.regexp, entity.name.tag, entity.other.attribute-name, meta.tag, declaration.tag, markup.deleted.git_gutter",
      "settings": { "foreground": "#6e5010" }
    },
    {
      "scope": "constant.numeric, constant.language, support.constant, constant.character, variable.parameter, punctuation.section.embedded, keyword.other.unit",
      "settings": { "foreground": "#534000", "fontStyle": "" }
    },
    {
      "scope": "entity.name.class, entity.name.type, entity.name.namespace, entity.name.scope-resolution, support.type, support.class",
      "settings": { "foreground": "#135f78", "fontStyle": "" }
    },
    {
      "scope": "string, constant.other.symbol, entity.other.inherited-class, markup.heading, markup.inserted.git_gutter",
      "settings": { "foreground": "#1a6650", "fontStyle": "" }
    },
    {
      "scope": "keyword.operator, constant.other.color",
      "settings": { "foreground": "#135f78" }
    },
    {
      "scope": "entity.name.function, meta.function-call, support.function, keyword.other.special-method, meta.block-level, markup.changed.git_gutter",
      "settings": { "foreground": "#0a3d5a", "fontStyle": "" }
    },
    {
      "scope": "keyword, storage, storage.type, entity.name.tag.css",
      "settings": { "foreground": "#1a5c7a", "fontStyle": "" }
    },
    {
      "scope": "invalid",
      "settings": { "foreground": "#800010", "fontStyle": "" }
    },
    {
      "scope": "meta.separator",
      "settings": { "foreground": "#0c1d45" }
    },
    {
      "scope": "invalid.deprecated",
      "settings": { "foreground": "#6e5010", "fontStyle": "" }
    },
    {
      "scope": "markup.quote",
      "settings": { "foreground": "#534000" }
    },
    {
      "scope": "markup.list",
      "settings": { "foreground": "#1a5c7a" }
    },
    {
      "scope": "markup.bold, markup.italic",
      "settings": { "foreground": "#534000" }
    },
    {
      "scope": "markup.inline.raw",
      "settings": { "foreground": "#6e5010", "fontStyle": "" }
    },
    {
      "scope": "token.info-token",
      "settings": { "foreground": "#1a5c7a" }
    },
    {
      "scope": "token.warn-token",
      "settings": { "foreground": "#6e5010" }
    },
    {
      "scope": "token.error-token",
      "settings": { "foreground": "#800010" }
    },
    {
      "scope": "token.debug-token",
      "settings": { "foreground": "#5c1e70" }
    }
  ]
}
