{
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "colors": {
    "activityBar.background": "#06102a",
    "activityBarBadge.background": "#007acc",
    "badge.background": "#437c90cc",
    "badge.foreground": "#06102a",
    "debugToolBar.background": "#091c38",
    "dropdown.background": "#0d2654",
    "editor.background": "#0f2440",
    "editor.foreground": "#e8eaf0",
    "editor.inactiveSelectionBackground": "#2a2d31",
    "editor.lineHighlightBackground": "#001d4a",
    "editor.selectionBackground": "#002870",
    "editor.selectionHighlightBackground": "#add6ff20",
    "editorCursor.foreground": "#e8eaf0",
    "editorGroup.border": "#2a3a60",
    "editorGroup.dropBackground": "#152040aa",
    "editorGroupHeader.tabsBackground": "#06102a",
    "editorHoverWidget.background": "#091c38",
    "editorHoverWidget.border": "#e8eaf040",
    "editorIndentGuide.activeBackground": "#606060",
    "editorIndentGuide.background": "#404040",
    "editorLineNumber.activeForeground": "#909090",
    "editorWhitespace.foreground": "#2a3a60",
    "editorWidget.background": "#091c38",
    "errorForeground": "#773d48",
    "focusBorder": "#5fb0ce",
    "input.background": "#0f2848",
    "input.placeholderForeground": "#9a9a9a",
    "list.activeSelectionBackground": "#163d70",
    "list.dropBackground": "#282b2d",
    "list.focusBackground": "#163d70",
    "list.highlightForeground": "#5fb0ce",
    "list.hoverBackground": "#e8eaf020",
    "list.inactiveSelectionBackground": "#e8eaf030",
    "menu.background": "#040c1f",
    "menu.foreground": "#c29532",
    "minimap.selectionHighlight": "#002870",
    "peekViewResult.background": "#091c38",
    "pickerGroup.foreground": "#5fb0ce",
    "progressBar.background": "#5fb0cecc",
    "settings.numberInputBackground": "#1a1a1a",
    "settings.textInputBackground": "#1a1a1a",
    "sideBar.background": "#091c38",
    "sideBar.foreground": "#7a8a9a",
    "auxiliaryBar.background": "#091c38",
    "auxiliaryBar.foreground": "#7a8a9a",
    "auxiliaryBar.border": "#cccccc22",
    "panel.background": "#091c38",
    "panel.border": "#cccccc22",
    "sideBarSectionHeader.background": "#00000000",
    "sideBarSectionHeader.border": "#cccccc33",
    "sideBarTitle.foreground": "#58687a",
    "statusBar.background": "#040c1f",
    "statusBar.foreground": "#7a8a9a",
    "statusBar.debuggingBackground": "#040c1f",
    "statusBar.noFolderBackground": "#040c1f",
    "statusBarItem.remoteBackground": "#0e639c",
    "statusBarItem.remoteForeground": "#ffffff",
    "tab.activeForeground": "#b0c4d8",
    "tab.inactiveForeground": "#5a6a7a",
    "tab.unfocusedActiveForeground": "#8aa4bc",
    "tab.unfocusedInactiveForeground": "#485868",
    "tab.inactiveBackground": "#091c38",
    "terminal.ansiBlack": "#111111",
    "terminal.ansiBlue": "#437c90",
    "terminal.ansiBrightBlack": "#888888",
    "terminal.ansiBrightBlue": "#80baff",
    "terminal.ansiBrightCyan": "#78ffff",
    "terminal.ansiBrightGreen": "#b8f171",
    "terminal.ansiBrightMagenta": "#d778ff",
    "terminal.ansiBrightRed": "#ff7882",
    "terminal.ansiBrightWhite": "#ffffff",
    "terminal.ansiBrightYellow": "#ffe580",
    "terminal.ansiCyan": "#99ffff",
    "terminal.ansiGreen": "#97d8c4",
    "terminal.ansiMagenta": "#30638e",
    "terminal.ansiRed": "#c29532",
    "terminal.ansiWhite": "#cccccc",
    "terminal.ansiYellow": "#ffeead",
    "titleBar.activeBackground": "#040c1f"
  },
  "tokenColors": [
    {
      "scope": ["meta.embedded", "source.groovy.embedded"],
      "settings": { "foreground": "#E4E4E4" }
    },
    { "scope": "emphasis", "settings": { "fontStyle": "italic" } },
    { "scope": "strong", "settings": { "fontStyle": "bold" } },
    { "scope": "header", "settings": { "foreground": "#000080" } },
    { "scope": "comment", "settings": { "foreground": "#80B36A" } },
    { "scope": "constant.language", "settings": { "foreground": "#70B0E8" } },
    {
      "scope": [
        "constant.numeric",
        "entity.name.operator.custom-literal.number",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": { "foreground": "#C8DEBC" }
    },
    { "scope": "constant.regexp", "settings": { "foreground": "#646695" } },
    { "scope": "entity.name.tag", "settings": { "foreground": "#70B0E8" } },
    { "scope": "entity.name.tag.css", "settings": { "foreground": "#E8CC8E" } },
    {
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#B4E6FF" }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.class.mixin.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.parent-selector.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css",
        "source.css.less entity.other.attribute-name.id",
        "entity.other.attribute-name.attribute.scss",
        "entity.other.attribute-name.scss"
      ],
      "settings": { "foreground": "#E8CC8E" }
    },
    { "scope": "invalid", "settings": { "foreground": "#F44747" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    {
      "scope": "markup.bold",
      "settings": { "foreground": "#70B0E8", "fontStyle": "bold" }
    },
    {
      "scope": "markup.heading",
      "settings": { "foreground": "#70B0E8", "fontStyle": "bold" }
    },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#C8DEBC" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#E0A888" } },
    { "scope": "markup.changed", "settings": { "foreground": "#70B0E8" } },
    {
      "scope": "punctuation.definition.quote.begin.markdown",
      "settings": { "foreground": "#80B36A" }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": { "foreground": "#80AAEE" }
    },
    {
      "scope": "markup.inline.raw",
      "settings": { "foreground": "#E0A888" }
    },
    {
      "scope": "punctuation.definition.tag",
      "settings": { "foreground": "#A0A0A0" }
    },
    {
      "scope": ["meta.preprocessor", "entity.name.function.preprocessor"],
      "settings": { "foreground": "#70B0E8" }
    },
    {
      "scope": "meta.preprocessor.string",
      "settings": { "foreground": "#E0A888" }
    },
    {
      "scope": "meta.preprocessor.numeric",
      "settings": { "foreground": "#C8DEBC" }
    },
    {
      "scope": "meta.structure.dictionary.key.python",
      "settings": { "foreground": "#B4E6FF" }
    },
    {
      "scope": "meta.diff.header",
      "settings": { "foreground": "#70B0E8" }
    },
    { "scope": "storage", "settings": { "foreground": "#70B0E8" } },
    { "scope": "storage.type", "settings": { "foreground": "#70B0E8" } },
    {
      "scope": ["storage.modifier", "keyword.operator.noexcept"],
      "settings": { "foreground": "#70B0E8" }
    },
    {
      "scope": ["string", "entity.name.operator.custom-literal.string", "meta.embedded.assembly"],
      "settings": { "foreground": "#E0A888" }
    },
    { "scope": "string.tag", "settings": { "foreground": "#E0A888" } },
    { "scope": "string.value", "settings": { "foreground": "#E0A888" } },
    { "scope": "string.regexp", "settings": { "foreground": "#E07878" } },
    {
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end",
        "punctuation.section.embedded"
      ],
      "settings": { "foreground": "#70B0E8" }
    },
    {
      "scope": ["meta.template.expression"],
      "settings": { "foreground": "#E4E4E4" }
    },
    {
      "scope": [
        "support.type.vendored.property-name",
        "support.type.property-name",
        "variable.css",
        "variable.scss",
        "variable.other.less",
        "source.coffee.embedded"
      ],
      "settings": { "foreground": "#B4E6FF" }
    },
    { "scope": "keyword", "settings": { "foreground": "#70B0E8" } },
    { "scope": "keyword.control", "settings": { "foreground": "#70B0E8" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#E4E4E4" } },
    {
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.alignof",
        "keyword.operator.typeid",
        "keyword.operator.alignas",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "keyword.operator.wordlike"
      ],
      "settings": { "foreground": "#70B0E8" }
    },
    {
      "scope": "keyword.other.unit",
      "settings": { "foreground": "#C8DEBC" }
    },
    {
      "scope": [
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php"
      ],
      "settings": { "foreground": "#70B0E8" }
    },
    {
      "scope": "support.function.git-rebase",
      "settings": { "foreground": "#B4E6FF" }
    },
    {
      "scope": "constant.sha.git-rebase",
      "settings": { "foreground": "#C8DEBC" }
    },
    {
      "scope": [
        "storage.modifier.import.java",
        "variable.language.wildcard.java",
        "storage.modifier.package.java"
      ],
      "settings": { "foreground": "#E4E4E4" }
    },
    { "scope": "variable.language", "settings": { "foreground": "#70B0E8" } },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "support.constant.handlebars",
        "source.powershell variable.other.member",
        "entity.name.operator.custom-literal"
      ],
      "settings": { "foreground": "#EEEEBB" }
    },
    {
      "scope": [
        "meta.return-type",
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.namespace",
        "entity.other.attribute",
        "entity.name.scope-resolution",
        "entity.name.class"
      ],
      "settings": { "foreground": "#6ADBC0" }
    },
    {
      "scope": [
        "keyword.control",
        "source.cpp keyword.operator.new",
        "keyword.operator.delete",
        "keyword.other.using",
        "keyword.other.operator",
        "entity.name.operator"
      ],
      "settings": { "foreground": "#D898D2" }
    },
    {
      "scope": ["variable", "meta.definition.variable.name", "support.variable", "entity.name.variable"],
      "settings": { "foreground": "#B4E6FF" }
    },
    {
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": { "foreground": "#68C8D6" }
    },
    {
      "scope": ["meta.object-literal.key"],
      "settings": { "foreground": "#B4E6FF" }
    },
    {
      "scope": "comment",
      "settings": { "foreground": "#8ABFAD" }
    },
    {
      "scope": "keyword.control",
      "settings": { "foreground": "#7FC4DE" }
    },
    {
      "scope": "keyword.operator.class, keyword.operator, constant.other, source.php.embedded.line",
      "settings": { "foreground": "#e8eaf0", "fontStyle": "" }
    },
    {
      "scope": "variable, support.other.variable, string.other.link, string.regexp, entity.name.tag, entity.other.attribute-name, meta.tag, declaration.tag, markup.deleted.git_gutter",
      "settings": { "foreground": "#D4A840" }
    },
    {
      "scope": "constant.numeric, constant.language, support.constant, constant.character, variable.parameter, punctuation.section.embedded, keyword.other.unit",
      "settings": { "foreground": "#E1C663", "fontStyle": "" }
    },
    {
      "scope": "entity.name.class, entity.name.type, entity.name.namespace, entity.name.scope-resolution, support.type, support.class",
      "settings": { "foreground": "#FFEEAD", "fontStyle": "" }
    },
    {
      "scope": "string, constant.other.symbol, entity.other.inherited-class, markup.heading, markup.inserted.git_gutter",
      "settings": { "foreground": "#AEE6D4", "fontStyle": "" }
    },
    {
      "scope": "keyword.operator, constant.other.color",
      "settings": { "foreground": "#99FFFF" }
    },
    {
      "scope": "entity.name.function, meta.function-call, support.function, keyword.other.special-method, meta.block-level, markup.changed.git_gutter",
      "settings": { "foreground": "#7FC4DE", "fontStyle": "" }
    },
    {
      "scope": "keyword, storage, storage.type, entity.name.tag.css",
      "settings": { "foreground": "#8ABCCC", "fontStyle": "" }
    },
    {
      "scope": "invalid",
      "settings": { "foreground": "#e8eaf0", "fontStyle": "" }
    },
    {
      "scope": "meta.separator",
      "settings": { "foreground": "#e8eaf0" }
    },
    {
      "scope": "invalid.deprecated",
      "settings": { "foreground": "#e8eaf0", "fontStyle": "" }
    },
    {
      "scope": "token.info-token",
      "settings": { "foreground": "#80AAEE" }
    },
    {
      "scope": "token.warn-token",
      "settings": { "foreground": "#CD9731" }
    },
    {
      "scope": "token.error-token",
      "settings": { "foreground": "#F44747" }
    },
    {
      "scope": "token.debug-token",
      "settings": { "foreground": "#C480F0" }
    }
  ]
}
